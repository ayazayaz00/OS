#include <iostream>
#include <vector>
#include <algorithm>
#include <cmath>
using namespace std;

// Print Gantt Chart
void printGantt(vector<int> seq) {
    cout << "\nGantt Chart:\n";
    for (int i : seq) {
        cout << "| " << i << " ";
    }
    cout << "|\n";
}

// ---------------- FCFS ----------------
void FCFS(vector<int> req, int head) {
    int total = 0;
    vector<int> seq;
    seq.push_back(head);

    for (int i : req) {
        total += abs(i - head);
        head = i;
        seq.push_back(head);
    }

    cout << "\n--- FCFS ---\n";
    printGantt(seq);
    cout << "Total Head Movement: " << total << endl;
}

// ---------------- SSTF ----------------
void SSTF(vector<int> req, int head) {
    int n = req.size(), total = 0;
    vector<bool> visited(n, false);
    vector<int> seq;
    seq.push_back(head);

    for (int i = 0; i < n; i++) {
        int minDist = INT_MAX, index = -1;

        for (int j = 0; j < n; j++) {
            if (!visited[j] && abs(req[j] - head) < minDist) {
                minDist = abs(req[j] - head);
                index = j;
            }
        }

        visited[index] = true;
        total += abs(req[index] - head);
        head = req[index];
        seq.push_back(head);
    }

    cout << "\n--- SSTF ---\n";
    printGantt(seq);
    cout << "Total Head Movement: " << total << endl;
}

// ---------------- SCAN ----------------
void SCAN(vector<int> req, int head, int diskSize) {
    vector<int> seq;
    int total = 0;

    req.push_back(head);
    sort(req.begin(), req.end());

    int idx = find(req.begin(), req.end(), head) - req.begin();

    seq.push_back(head);

    // Move right
    for (int i = idx + 1; i < req.size(); i++) {
        total += abs(req[i] - head);
        head = req[i];
        seq.push_back(head);
    }

    // Go to end
    total += abs((diskSize - 1) - head);
    head = diskSize - 1;
    seq.push_back(head);

    // Move left
    for (int i = idx - 1; i >= 0; i--) {
        total += abs(req[i] - head);
        head = req[i];
        seq.push_back(head);
    }

    cout << "\n--- SCAN ---\n";
    printGantt(seq);
    cout << "Total Head Movement: " << total << endl;
}

// ---------------- C-SCAN ----------------
void CSCAN(vector<int> req, int head, int diskSize) {
    vector<int> seq;
    int total = 0;

    req.push_back(head);
    sort(req.begin(), req.end());

    int idx = find(req.begin(), req.end(), head) - req.begin();

    seq.push_back(head);

    // Move right
    for (int i = idx + 1; i < req.size(); i++) {
        total += abs(req[i] - head);
        head = req[i];
        seq.push_back(head);
    }

    // Jump to start
    total += abs((diskSize - 1) - head);
    head = 0;
    total += (diskSize - 1);
    seq.push_back(diskSize - 1);
    seq.push_back(head);

    // Continue from start
    for (int i = 0; i < idx; i++) {
        total += abs(req[i] - head);
        head = req[i];
        seq.push_back(head);
    }

    cout << "\n--- C-SCAN ---\n";
    printGantt(seq);
    cout << "Total Head Movement: " << total << endl;
}


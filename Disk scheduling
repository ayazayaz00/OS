    vector<int> seq;
    int total = 0;

    req.push_back(head);
    sort(req.begin(), req.end());

    int idx = find(req.begin(), req.end(), head) - req.begin();

    seq.push_back(head);

    // Move right
    for (int i = idx + 1; i < req.size(); i++) {
